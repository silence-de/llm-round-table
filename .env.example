# Shared access gate for non-localhost deployments.
ROUND_TABLE_ACCESS_TOKEN=

# Local storage and runtime paths.
ROUND_TABLE_DB_PATH=./data/round-table.db
ROUND_TABLE_DATA_DIR=./data
ROUND_TABLE_PDF_CJK_FONT=

# Research and evidence capture.
TAVILY_API_KEY=
# Playwright package + Chromium browser are also recommended for DOM capture.
ROUND_TABLE_DISABLE_PLAYWRIGHT_DOM_CAPTURE=0
ROUND_TABLE_DISABLE_SCREENSHOT_CAPTURE=0

# Model provider keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SILICONFLOW_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# Optional provider endpoints.
DEEPSEEK_BASE_URL=
MOONSHOT_BASE_URL=

# Optional model overrides.
CLAUDE_MODEL_ID=
GPT_MODEL_ID=
DEEPSEEK_MODEL_ID=
MINIMAX_MODEL_ID=
KIMI_MODEL_ID=
GLM_MODEL_ID=
QWEN_MODEL_ID=

# Session defaults and orchestration tuning.
DEFAULT_MODERATOR=claude
MAX_DEBATE_ROUNDS=2
DEFAULT_TEMPERATURE=0.7
MAX_CONCURRENT_AGENTS=3
ROUND_TABLE_AGENT_DEGRADE_TIMEOUT_THRESHOLD=2
ROUND_TABLE_SILICONFLOW_BATCH_SIZE=1
SILICONFLOW_MAX_CONCURRENCY=1

# Provider timeout tuning.
SILICONFLOW_TIMEOUT_MS=240000
SILICONFLOW_QWEN_TIMEOUT_MS=300000
SILICONFLOW_CLIENT_TIMEOUT_MS=310000
DEEPSEEK_TIMEOUT_MS=135000
DEEPSEEK_REASONER_TIMEOUT_MS=150000
DEEPSEEK_CLIENT_TIMEOUT_MS=155000
MOONSHOT_TIMEOUT_MS=135000
MOONSHOT_PREVIEW_TIMEOUT_MS=150000
MOONSHOT_CLIENT_TIMEOUT_MS=155000
